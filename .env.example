# Copy this file to .env.local and fill in your values, then restart `npm run dev`.
# The API key is read by the browser at build time (Vite inlines VITE_* vars).
# Use a low-privilege ALS API key scoped to geo-maps + geo-places, ideally with a
# referer restriction and an expiry. Never commit .env.local.

VITE_ALS_API_KEY=your-als-api-key-here
VITE_AWS_REGION=us-east-1
